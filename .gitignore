# Python / uv
.venv/
__pycache__/
*.py[cod]
.uv/
.jax_cache/

# Claude Code local settings and scratch writes — not shared in the repo
.claude/

# Downloaded weights & data (large; fetched from HuggingFace on demand)
model_checkpoints/
data/
# Demo J's ``data`` package contains source code, not downloaded datasets.
!demo_j/data/
!demo_j/data/*.py
*.h5
# Trained motor checkpoints — regenerated via make_assets.py / training; repo policy: weights not committed
*.pt

# Training artifacts
highlvl_checkpoints/
task_checkpoints/
outputs/
wandb/
videos/
*.mp4

# Committed workshop showcase videos for the README — an explicit exception to
# the global *.mp4 ignore above. Only this folder's mp4s are tracked.
!attachments/
!attachments/*.mp4

# MuJoCo
MUJOCO_LOG.TXT

runs/

# Secrets — remote auth uses exported env vars (no .env). These stay ignored
# defensively in case one is ever created locally.
.env
rl/remote/.env

